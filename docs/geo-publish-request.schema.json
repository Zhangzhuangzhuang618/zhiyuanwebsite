{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://www.zhiyuanbj.cn/schemas/geo-publish-request-1.json",
  "title": "Zhiyuan GEO news publish request",
  "type": "object",
  "additionalProperties": false,
  "required": ["content_version_id", "payload_hash", "payload"],
  "properties": {
    "content_version_id": { "type": "string", "format": "uuid" },
    "payload_hash": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "payload": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schema_version",
        "platform_code",
        "title",
        "summary",
        "body_html",
        "seo_keywords",
        "meta_description"
      ],
      "properties": {
        "schema_version": { "const": "zhiyuan-news-payload@1" },
        "platform_code": { "const": "official_site" },
        "title": { "type": "string", "minLength": 20, "maxLength": 60 },
        "summary": { "type": "string", "minLength": 1, "maxLength": 240 },
        "body_html": { "type": "string", "minLength": 1, "maxLength": 500000 },
        "seo_keywords": {
          "type": "array",
          "maxItems": 20,
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1, "maxLength": 40 }
        },
        "meta_description": { "type": "string", "minLength": 1, "maxLength": 240 }
      }
    }
  }
}
